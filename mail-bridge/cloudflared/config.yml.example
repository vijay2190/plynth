# Cloudflare Tunnel config for the Plynth mail bridge.
# Steps to set up (one-time):
#   1. cloudflared tunnel login                       # opens browser, picks domain
#   2. cloudflared tunnel create plynth-mail          # generates UUID + creds JSON
#   3. cloudflared tunnel route dns plynth-mail plynth-mail.<your-domain>
#   4. Copy this file to ~/.cloudflared/config.yml and edit:
#        - tunnel: <UUID-from-step-2>
#        - credentials-file: ~/.cloudflared/<UUID>.json
#        - hostname: plynth-mail.<your-domain>
#   5. sudo cloudflared service install               # runs as systemd
#
# If you don't have a Cloudflare-managed domain, use a quick named tunnel:
#   cloudflared tunnel --url http://127.0.0.1:5556
# It will print a *.trycloudflare.com URL — copy it into Supabase Vault as MAIL_BRIDGE_URL.

tunnel: REPLACE-WITH-TUNNEL-UUID
credentials-file: /home/vijay/.cloudflared/REPLACE-WITH-TUNNEL-UUID.json

ingress:
  - hostname: plynth-mail.example.com
    service: http://127.0.0.1:5556
    originRequest:
      connectTimeout: 5s
      noTLSVerify: false
  - service: http_status:404
